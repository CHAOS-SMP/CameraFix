    "repo": "https://github.com/CHAOS-SMP/CameraFix"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "main": ["cn.chaosmp.camerafix.fabric.FabricMain"]
  },
  "mixins": ["camerafix.mixins.json"],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": ">=${minecraft_version}",
    "fabric-api": "*"
  }
}
